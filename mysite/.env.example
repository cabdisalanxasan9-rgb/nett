# Copy this file to .env and replace placeholders with your real values.
# Never commit .env to source control.

OPENAI_API_KEY=sk-your-real-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Stripe Billing (required for Pro checkout)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
PRO_FEATURES_REQUIRE_PAYMENT=true
ALLOW_DEV_PRO_UPGRADE_WITHOUT_STRIPE=false

# Zaad manual billing fallback
ZAAD_MANUAL_PAYMENT_ENABLED=true
ZAAD_MERCHANT_NUMBER=25263xxxxxxx
ZAAD_PRO_AMOUNT=5
ZAAD_PRO_CURRENCY=USD
PAYMENT_ZAAD_ACCOUNT=25263xxxxxxx
PAYMENT_EVC_ACCOUNT=25261xxxxxxx
PAYMENT_SAHAL_ACCOUNT=25290xxxxxxx
PAYMENT_BANK_NAME=Salaam Bank
PAYMENT_BANK_ACCOUNT=1234567890

# Deployment (Vercel)
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_ALLOWED_HOSTS=.vercel.app
DJANGO_FORCE_HTTPS=true
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
ACCOUNT_REQUIRE_EMAIL_VERIFICATION=false

# Production database (recommended for Vercel)
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=
